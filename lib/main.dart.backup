/// Request notification permissions for both platforms
Future<void> _requestNotificationPermissions() async {
  try {
    // Request FCM permissions
    await FirebaseMessaging.instance.requestPermission(
      alert: true,
      badge: true,
      sound: true,
      provisional: false,
    );
    
    // Android-specific permission handling
    if (Platform.isAndroid) {
      // Request notification permission only for Android 13+
      if (Platform.version.contains('Android 13')) {
        await Permission.notification.request();
      }
    }
    
    print("✅ Notification permissions configured");
  } catch (e) {
    print("❌ Error requesting notification permissions: $e");
  }
}

Future<void> _initializeApp() async {
  print("Main: Starting app initialization");
  
  // Initialize basic Flutter bindings
  WidgetsFlutterBinding.ensureInitialized();
  print("Main: WidgetsFlutterBinding initialized");

  // Initialize storage
  await GetStorage.init();
  print("Main: GetStorage initialized");

  // Initialize localization
  final delegate = await LocalizationDelegate.create(
    fallbackLocale: 'en_US',
    supportedLocales: ['en_US', 'ar', 'es', 'ne', 'fa', 'in', 'pt', 'ru', 'de', 'tr', 'fr'],
  );
  print("Main: Localization delegate created");

  // Initialize Firebase
  if (Firebase.apps.isEmpty) {
    await Firebase.initializeApp(options: DefaultFirebaseOptions.currentPlatform);
    print("Main: Firebase initialized successfully");
  }

  // Initialize all messaging and notification services
  await _initializeMessagingServices();
  print("Main: Messaging services initialized");

  // Start the app with all required wrappers
  runApp(
    LocalizedApp(
      delegate,
      InAppNotification(
        child: OverlaySupport(
          child: MyApp(),
        ),
      ),
    ),
  );
  
  // Configure loading overlay
  configLoading();
  print("Main: App initialized successfully");
}

Future<void> main() async {
  try {
    // Initialize Flutter bindings
    WidgetsFlutterBinding.ensureInitialized();

    // Initialize storage
    await GetStorage.init();

    // Initialize localization
    final delegate = await LocalizationDelegate.create(
      fallbackLocale: 'en_US',
      supportedLocales: ['en_US', 'ar', 'es', 'ne', 'fa', 'in', 'pt', 'ru', 'de', 'tr', 'fr'],
    );

    // Initialize Firebase
    if (Firebase.apps.isEmpty) {
      await Firebase.initializeApp(options: DefaultFirebaseOptions.currentPlatform);
    }

    // Set background message handler
    FirebaseMessaging.onBackgroundMessage(fcmBackgroundMessageHandler);

    // Initialize services
    await NotificationService.initialize();
    await FCMService.initialize();
    await RealtimeChatService.initialize();
    await GlobalMessagePollingService().initializeConversationCache();
    AppLifecycleService().initialize();

    // Set high refresh rate on Android
    if (Platform.isAndroid) {
      await FlutterDisplayMode.setHighRefreshRate();
    }

    // Run app
    runApp(
      LocalizedApp(
        delegate, 
        InAppNotification(
          child: const MyApp(),
        ),
      ),
    );
    configLoading();
  } catch (e, stack) {
    print('Fatal error during app initialization: $e\n$stack');
    // Run minimal app showing error
    runApp(MaterialApp(
      home: Scaffold(
        body: Center(
          child: Text('Error starting app: $e'),
        ),
      ),
    ));
  }

  try {
    // Initialize storage first
    await GetStorage.init();
    print("Main: GetStorage initialized");

    print('✅ Firebase and messaging services initialized successfully');

    // FCM and local storage are now the primary data methods
    if (kDebugMode) {
      print('� Initializing local storage and FCM...');
      print('💾 Data will be stored locally as requested');
      print('🔔 Push notifications enabled via FCM');
    }
    // Request permissions through notification service
    await _requestNotificationPermissions();

    // Set high refresh rate on Android
    if (Platform.isAndroid) {
      await FlutterDisplayMode.setHighRefreshRate();
    }

    try {
      // Use only NotificationService for handling notifications
      await NotificationService.initialize();
      print('✅ Notification service initialized');
    } catch (e) {
      print('❌ Failed to initialize notification service: $e');
    }
    // NotificationService will handle all notification events
    } catch (e) {
      print('❌ Error setting up notification permissions: $e');
    }

    // Set to track processed message IDs
    final Set<String> processedMessageIds = {};
    
    FirebaseMessaging.onMessage.listen((event) {
      // Check if we've already processed this message
      String messageId = event.messageId ?? DateTime.now().toIso8601String();
      if (processedMessageIds.contains(messageId)) {
        print('🚫 Duplicate message detected, skipping notification');
        return;
      }
      
      // Add to processed messages
      processedMessageIds.add(messageId);
      
      // Clean up after 5 minutes to prevent memory leaks
      Future.delayed(Duration(minutes: 5), () {
        processedMessageIds.remove(messageId);
      });

      try {
        FlutterRingtonePlayer().play(
          fromAsset: "assets/sound/beep.mp3",
        );
      } catch (e) {
        print('⚠️ Failed to play notification sound: $e');
        // Fallback to system sound
        try {
          FlutterRingtonePlayer().playNotification();
        } catch (fallbackError) {
          print('⚠️ Failed to play fallback sound: $fallbackError');
        }
      }

      try {
        InAppNotification.show(
          onTap: () {
            if (event.data['type'] == 'chat') {
              Get.to(() => ChatScreen(), arguments: {
                "name": event.data["sender_name"],
                "avatar": event.data["sender_image"],
                "username": event.data["sender_username"],
              });
            } else if (event.data['type'] == 'group_chat') {
              Get.to(() => ChatScreen(), arguments: {
                "projectName": event.data["project_name"] ?? "",
                "projectId": event.data["project_id"] ?? "",
                "conversationId": event.data["conversation_id"] ?? "",
              });
            } else {
              Get.to(() => GeneralScreen(), arguments: {
                "title": event.notification!.title!,
                "message": event.notification!.body!,
                "date": ""
              });
            }
          },
          child: Card(
            margin: const EdgeInsets.all(15),
            child: ListTile(
              shape: RoundedRectangleBorder(
                  borderRadius: BorderRadius.circular(25)),
              iconColor: HexColor("#011754"),
              textColor: HexColor("#011754"),
              minVerticalPadding: 10,
              minLeadingWidth: 0,
              tileColor: Colors.white,
              title: Row(
                children: [
                  Container(child: Icon(Icons.notifications)),
                  SizedBox(
                    width: 10,
                  ),
                  Expanded(
                    child: Text(
                      event.notification!.title!,
                    ),
                  ),
                ],
              ),
              subtitle: Padding(
                padding: const EdgeInsets.symmetric(vertical: 8.0),
                child: Text(
                  event.notification!.body!,
                  textAlign: TextAlign.justify,
                  style: TextStyle(color: Colors.grey),
                ),
              ),
            ),
          ),
          context: NavigationService.navigatorKey.currentState!.context,
        );
      } catch (e) {
        print(e);
      }
    });

    FirebaseMessaging.onMessageOpenedApp.listen((message) {
      print('📱 Notification tapped (onMessageOpenedApp): ${message.data}');
      
      if (message.data.containsKey("type")) {
        String type = message.data["type"];
        print('📱 Message type: $type');
        
        switch (type) {
          case "chat":
            Get.to(() => ChatScreen(), arguments: {
              "name": message.data["sender_name"],
              "avatar": message.data["sender_image"],
              "username": message.data["sender_username"],
            });
            break;
          case "group_chat":
            Get.to(() => ChatScreen(), arguments: {
              "projectName": message.data["project_name"] ?? "",
              "projectId": message.data["project_id"] ?? "",
              "conversationId": message.data["conversation_id"] ?? "",
            });
            break;
          default:
            Get.to(() => GeneralScreen(), arguments: {
              "title": message.data["title"] ?? message.notification?.title ?? "Notification",
              "message": message.data["message"] ?? message.notification?.body ?? "New message",
              "date": ""
            });
            break;
        }
      }
    });

    ByteData data =
        await PlatformAssetBundle().load('assets/ca/lets-encrypt-r3.pem');
    SecurityContext.defaultContext
        .setTrustedCertificatesBytes(data.buffer.asUint8List());

    print("Main: About to run app");
    runApp(LocalizedApp(delegate, MyApp()));
    configLoading();
    print("Main: App started and configLoading called");
    runApp(LocalizedApp(delegate, MyApp()));
    configLoading();
  } catch (error, stackTrace) {
    print('Error during app initialization: $error');
    print('Stack trace: $stackTrace');

    // Fallback: Try to start the app with minimal configuration
    try {
      WidgetsFlutterBinding.ensureInitialized();
      await GetStorage.init();

      // Create a minimal delegate for fallback
      var fallbackDelegate = await LocalizationDelegate.create(
          fallbackLocale: 'en_US', supportedLocales: ['en_US']);

      runApp(LocalizedApp(fallbackDelegate, MyApp()));
    } catch (fallbackError) {
      print('Fallback initialization failed: $fallbackError');
      // As a last resort, start with a basic MaterialApp
      runApp(MaterialApp(
        home: Scaffold(
          body: Center(
            child: Column(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                Text('Initialization Error'),
                Text('$error'),
                ElevatedButton(
                  onPressed: () {
                    // Try to restart the app
                    main();
                  },
                  child: Text('Retry'),
                ),
              ],
            ),
          ),
        ),
      ));
    }
  }
}

void configLoading() {
  EasyLoading.instance
    ..indicatorType = EasyLoadingIndicatorType.cubeGrid
    ..loadingStyle = EasyLoadingStyle.dark
    ..indicatorSize = 50.0
    ..radius = 0.0
    ..progressColor = Colors.blue
    ..backgroundColor = Colors.white
    ..indicatorColor = Colors.blue
    ..textColor = Colors.black
    ..maskType = EasyLoadingMaskType.none
    ..userInteractions = false
    ..dismissOnTap = false;
}

class MyApp extends StatelessWidget {
  const MyApp({Key? key}) : super(key: key);

  @override
  Widget build(BuildContext context) {
    try {
      final localizationDelegate = LocalizedApp.of(context).delegate;
      
      return MultiProvider(
        providers: [
          ChangeNotifierProvider(create: (_) => Auth()),
          ChangeNotifierProvider(create: (_) => Preferences()),
          ChangeNotifierProvider(create: (_) => LeaveProvider()),
          ChangeNotifierProvider(create: (_) => PrefProvider()),
          ChangeNotifierProvider(create: (_) => ProfileProvider()),
          ChangeNotifierProvider(create: (_) => AttendanceReportProvider()),
          ChangeNotifierProvider(create: (_) => DashboardProvider()),
          ChangeNotifierProvider(create: (_) => MoreScreenProvider()),
          ChangeNotifierProvider(create: (_) => PaySlipProvider()),
          ChangeNotifierProvider(create: (_) => PaySlipDetailProvider()),
        ],
        child: MaterialApp(
          home: SplashScreen(),
          builder: EasyLoading.init(),
        ),
      );
    } catch (e) {
      print('Error building app: $e');
      return MaterialApp(
        home: SplashScreen(),
        builder: EasyLoading.init(),
      );
    }
  }

  @override
  State<_AppWrapper> createState() => _AppWrapperState();
}

class _AppWrapperState extends State<_AppWrapper> with WidgetsBindingObserver {
  @override
  void initState() {
    super.initState();
    WidgetsBinding.instance.addObserver(this);
  }

  @override
  void dispose() {
    _cleanupServices();
    WidgetsBinding.instance.removeObserver(this);
    super.dispose();
  }

  Future<void> _cleanupServices() async {
    try {
      await NotificationService.cleanup();
    } catch (e) {
      print('Error cleaning up notification service: $e');
    }
  }

  @override
  void didChangeAppLifecycleState(AppLifecycleState state) async {
    switch (state) {
      case AppLifecycleState.paused:
      case AppLifecycleState.detached:
        // Clean up notification listeners when app is backgrounded
        await _cleanupServices();
        break;
      case AppLifecycleState.resumed:
        // Re-initialize notification listeners when app is resumed
        try {
          await NotificationService.initialize();
        } catch (e) {
          print('Error reinitializing notification service: $e');
        }
        break;
      default:
        break;
    }
  }

  @override
  Widget build(BuildContext context) {
    try {
      // Try to get the localization delegate safely
      final localizationDelegate = LocalizedApp.of(context).delegate;
      
      return GetMaterialApp(
        debugShowCheckedModeBanner: false,
        navigatorKey: NavigationService.navigatorKey,
        localizationsDelegates: [
          GlobalMaterialLocalizations.delegate,
          GlobalWidgetsLocalizations.delegate,
          localizationDelegate,
        ],
        supportedLocales: localizationDelegate.supportedLocales,
        locale: localizationDelegate.currentLocale,
        theme: ThemeData(
          colorScheme: ColorScheme.fromSeed(seedColor: Colors.blue),
          useMaterial3: true,
        ),
        home: SplashScreen(),
        builder: EasyLoading.init(),
      );
    } catch (e) {
      print('Error building app: $e');
      // Fallback to basic Material app
      return MaterialApp(
        home: SplashScreen(),
        builder: EasyLoading.init(),
      );
    }
  }
}

  // This widget is the root of your application.
  @override
  Widget build(BuildContext context) {
    try {
      // Try to get the localization delegate safely
      LocalizationDelegate? localizationDelegate;
      try {
        localizationDelegate = LocalizedApp.of(context).delegate;
      } catch (e) {
        print('Could not get localization delegate: $e');
        // Create a fallback delegate
        return FutureBuilder<LocalizationDelegate>(
          future: LocalizationDelegate.create(
            fallbackLocale: 'en_US',
            supportedLocales: ['en_US'],
          ),
          builder: (context, snapshot) {
            if (snapshot.hasData) {
              return LocalizedApp(snapshot.data!, const MyAppContent());
            }
            return MaterialApp(
              debugShowCheckedModeBanner: false,
              home: Scaffold(
                body: Center(
                  child: CircularProgressIndicator(),
                ),
              ),
            );
          },
        );
      }

      return MyAppContent(localizationDelegate: localizationDelegate);
    } catch (error, stackTrace) {
      print('Error in MyApp build: $error');
      print('Stack trace: $stackTrace');

      // Return a fallback UI
      return MaterialApp(
        debugShowCheckedModeBanner: false,
        home: Scaffold(
          body: Center(
            child: Column(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                Icon(Icons.error_outline, size: 64, color: Colors.red),
                SizedBox(height: 16),
                Text('App Initialization Error',
                    style:
                        TextStyle(fontSize: 18, fontWeight: FontWeight.bold)),
                SizedBox(height: 8),
                Text('$error',
                    textAlign: TextAlign.center,
                    style: TextStyle(fontSize: 14)),
                SizedBox(height: 16),
                ElevatedButton(
                  onPressed: () {
                    // Try to restart the app
                    main();
                  },
                  child: Text('Retry'),
                ),
              ],
            ),
          ),
        ),
      );
    }
  }
}

